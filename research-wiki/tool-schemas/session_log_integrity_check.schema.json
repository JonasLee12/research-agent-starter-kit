{
  "name": "session_log_integrity_check",
  "version": "2026-06-11",
  "inputs_required": [
    "SESSION_EVENT_LOG_jsonl",
    "runtime_receipt_directory",
    "strict_mode"
  ],
  "outputs_expected": [
    "parseability_status",
    "blocking_issue_count",
    "warning_count",
    "optional_markdown_report"
  ],
  "preconditions": [
    "research-wiki/SESSION_EVENT_LOG.jsonl_available_or_explicit_log_path",
    "runtime_receipts_available_when_window_alignment_is_checked"
  ],
  "quality_gate": [
    "JSONL_lines_parse",
    "window_labels_are_Production_or_Maintenance",
    "session_start_and_session_end_are_balanced_by_run_id",
    "event_windows_match_runtime_receipt_windows_when_receipts_exist",
    "timestamps_parse_and_do_not_move_backwards_within_run_id_unless_warn_only"
  ],
  "failure_modes": [
    "missing_log_file",
    "invalid_json_line",
    "illegal_window_label",
    "runtime_window_mismatch",
    "unpaired_session_start",
    "unparseable_timestamp"
  ]
}
